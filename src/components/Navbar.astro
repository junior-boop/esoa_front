---
import { Image } from "astro:assets";
import Container from "./Container.astro";
import icons from "../assets/icons.svg";
import { RiMenu3Line } from "./icons.tsx";
---

<nav>
  <Container class='h-16 hidden lg:block'>
    <div class='flex items-center justify-between h-full relative'>
      <div class='h-full flex items-center gap-6'>
        <a href='/academie'>Academie</a>
        <a href='/centres'>nos centres</a>
      </div>
      <a href='/' class='absolute top-2.5 left-1/2 transform -translate-x-1/2'>
        <img src={icons.src} alt='Logo' class={"w-15.5"} />
      </a>
      <div class='h-full flex items-center gap-6'>
        <a href='#' class='nav-cta'>Inscriptions</a>
        <a href='#'>Contact</a>
      </div>
    </div>
  </Container>

  <Container class='h-16 block lg:hidden'>
    <div class='flex items-center justify-between h-full relative'>
      <a href='/' class='py-4'>
        <img src={icons.src} alt='Logo' class={"w-15.5"} />
      </a>
      <button
        id='menu-toggle'
        class='bg-black text-white px-2 py-2 rounded-md'
        aria-label='Toggle menu'>
        <RiMenu3Line width={24} height={24} />
      </button>
    </div>
  </Container>

  <!-- Menu Mobile -->
  <div id='mobile-menu' class='mobile-menu hidden'>
    <div class='mobile-menu-content'>
      <a href='/academie' class='mobile-menu-link'>Academie</a>
      <a href='/centres' class='mobile-menu-link'>Nos Centres</a>
      <a href='#' class='mobile-menu-link mobile-menu-cta'>Inscriptions</a>
      <a href='#' class='mobile-menu-link'>Contact</a>
    </div>
  </div>

  <style>
    nav {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(50px);
      border-bottom: 1px solid white;
    }

    nav a {
      text-decoration: none;
      font-weight: 600;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    .nav-brand {
      font-weight: bold;
      font-size: 1.25rem;
    }

    .nav-cta {
      padding: 8px 16px;
      background: black;
      color: white;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s;
    }

    .nav-cta:hover {
      background: #333;
    }

    /* Menu Mobile */
    .mobile-menu {
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(50px);
      border-bottom: 1px solid #e5e7eb;
      z-index: 50;
      animation: slideDown 300ms ease-out forwards;
    }

    .mobile-menu.hidden {
      display: none;
      animation: slideUp 300ms ease-out forwards;
    }

    @keyframes slideDown {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideUp {
      from {
        opacity: 1;
        transform: translateY(0);
      }
      to {
        opacity: 0;
        transform: translateY(-10px);
      }
    }

    .mobile-menu-content {
      display: flex;
      flex-direction: column;
      padding: 16px 0;
    }

    .mobile-menu-link {
      padding: 12px 16px;
      text-decoration: none;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 14px;
      color: #000;
      transition:
        background-color 0.2s,
        color 0.2s;
    }

    .mobile-menu-link:hover {
      background-color: #f3f4f6;
    }

    .mobile-menu-cta {
      background-color: #000;
      color: #fff;
      margin: 8px 8px 0 8px;
      border-radius: 6px;
      padding: 12px 16px;
    }

    .mobile-menu-cta:hover {
      background-color: #333;
    }

    #menu-toggle {
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background-color 0.2s;
    }

    #menu-toggle:hover {
      background-color: #333;
    }
  </style>
</nav>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuLinks = document.querySelectorAll(".mobile-menu-link");

  if (menuToggle) {
    // Toggle le menu au clic sur le bouton
    menuToggle.addEventListener("click", () => {
      mobileMenu.classList.toggle("hidden");
    });

    // Ferme le menu quand on clique sur un lien
    menuLinks.forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.add("hidden");
      });
    });

    // Ferme le menu si on clique en dehors
    document.addEventListener("click", (e) => {
      if (!menuToggle.contains(e.target) && !mobileMenu.contains(e.target)) {
        mobileMenu.classList.add("hidden");
      }
    });
  }
</script>
