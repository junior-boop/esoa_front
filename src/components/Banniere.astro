---
import Container from "./Container.astro";
import about_hero from "../assets/image/about_hero.png";
---

<section class='bg-white'>
  <Container style={{ padding: 0 }}>
    <div class='flex flex-col lg:flex-row items-center h-[750px] lg:h-[550px]'>
      <div class='flex-1 flex flex-col items-center justify-center'>
        <p
          class='uppercase inter text-center lg:text-left text-xl text-[#F35E0E] mb-0'>
          Académie
        </p>
        <h3
          class='titre text-4xl lg:text-[64px] text-center lg:text-left font-bold inter mb-8 uppercase'>
          Notre histoire, <br />
          notre mission
        </h3>

        <p class='inter text-2xl w-[80%] text-center lg:text-left'>
          accroche résumant l'identité de l'académie
        </p>
      </div>
      <div class='flex-1 overflow-hidden rounded-none lg:rounded-3xl'>
        <img
          src={about_hero.src}
          alt='About Hero Image'
          class='w-full h-full object-cover'
        />
      </div>
    </div>
  </Container>
</section>

<style>
  .titre {
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
</style>
