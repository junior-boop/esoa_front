---
import { RiArrowRightUpLine } from "./icons";

interface Props {
  name: string;
  src: string;
  alt?: string;
}

const name = Astro.props.name;
const src = Astro.props.src;
const alt = Astro.props.alt || "Centre image";
---

<a
  href='/'
  class='relative rounded-2xl overflow-hidden h-[250px] lg:h-120 cursor-pointer'>
  <img src={src} alt={alt} class='w-full h-full object-cover' />
  <div class='centre-label bebas-neue-regular text-2xl lg:text-4xl'>
    {name}
    <RiArrowRightUpLine width='42' height='42' />
  </div>
</a>

<style>
  .centre-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
    filter: brightness(0.75);
  }

  .centre-card:hover img {
    transform: scale(1.06);
    filter: brightness(0.6);
  }

  .centre-label {
    position: absolute;
    bottom: 1rem;
    left: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--white);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
</style>
